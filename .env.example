# ─────────────────────────────────────────────
# REQUIRED: Google Gemini (Primary LLM)
# ─────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here
LLM_MODEL=gemini/gemini-3.1-flash-lite-preview

# ─────────────────────────────────────────────
# OPTIONAL: Groq (Fallback / Legacy)
# ─────────────────────────────────────────────
GROQ_API_KEY=



# ─────────────────────────────────────────────
# EMBEDDING & RETRIEVAL
# ─────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_PATH=./data/vectorstore_hf
CHUNK_SIZE=800
CHUNK_OVERLAP=200
RETRIEVER_K=3

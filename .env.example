# --- REQUIRED: LLM CONFIGURATION ---
# Primary Engine: Google Gemini 3.1 Flash Lite (High-Speed Agentic Reasoning)
GOOGLE_API_KEY=your_google_api_key_here

# Current State-of-the-Art Model Identifier
LLM_MODEL=gemini/gemini-3.1-flash-lite-preview

# --- OPTIONAL: FALLBACK / LEGACY CONFIG ---
GROQ_API_KEY=

# --- SYSTEM SETTINGS ---
# Local Embedding Model (No API cost)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage and Retrieval
VECTOR_STORE_PATH=./data/vectorstore_hf
CHUNK_SIZE=800
CHUNK_OVERLAP=200
RETRIEVER_K=3
